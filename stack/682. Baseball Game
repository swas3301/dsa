class Solution(object):
    def calPoints(self, operations):
        
        rec = []
        for i in range(0,len(operations)):
            if operations[i] == "+":
                rec.append(rec[-1] + rec[-2])
            elif operations[i] == "D":
                rec.append(2*rec[-1])
            elif operations[i] == "C":
                rec.pop()
            else:
                rec.append(int(operations[i]))
        sum = 0
        for i in rec:
            sum += i
        return sum

        """
        :type operations: List[str]
        :rtype: int
        """
        
